# Keystatic storage mode: local (development) or github (remote/production)
KEYSTATIC_STORAGE_KIND=local

# Required when KEYSTATIC_STORAGE_KIND=github
KEYSTATIC_GITHUB_REPO=owner/repository

# Required for GitHub OAuth in /api/keystatic/*
KEYSTATIC_GITHUB_CLIENT_ID=your_github_oauth_client_id
KEYSTATIC_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
KEYSTATIC_SECRET=replace_with_long_random_secret

# Optional when using GitHub App flow
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
