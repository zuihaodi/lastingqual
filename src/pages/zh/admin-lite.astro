---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import { navZh } from "../../i18n/nav";
import { navEn } from "../../i18n/nav";
import { financeSolutionsZh } from "../../data/finance.zh";
import { financeSolutionsEn } from "../../data/finance.en";

const bootstrap = {
  navZh,
  navEn,
  financeZh: financeSolutionsZh,
  financeEn: financeSolutionsEn,
};
---

<Layout title="前端管理 | Lasting Qual" lang="zh-CN">
  <Header />

  <main class="bg-gray-50 min-h-screen py-10">
    <div class="max-w-6xl mx-auto px-4 space-y-8">
      <div class="bg-white rounded-lg p-6 shadow-sm">
        <h1 class="text-2xl font-bold text-[#003865]">前端轻量管理</h1>
        <p class="text-sm text-gray-600 mt-2">支持导航与融资栏目内容的增改删，数据保存在当前浏览器 localStorage。</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <section class="bg-white rounded-lg p-6 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-[#003865]">中文导航</h2>
            <button data-toggle-target="panel-nav-zh" class="text-sm border border-gray-300 px-3 py-1 rounded">收起</button>
          </div>
          <div id="panel-nav-zh">
            <div id="nav-zh-list" class="space-y-3"></div>
            <button id="add-nav-zh" class="mt-4 bg-[#003865] text-white px-4 py-2 rounded text-sm">新增导航项</button>
          </div>
        </section>

        <section class="bg-white rounded-lg p-6 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-[#003865]">英文导航</h2>
            <button data-toggle-target="panel-nav-en" class="text-sm border border-gray-300 px-3 py-1 rounded">收起</button>
          </div>
          <div id="panel-nav-en">
            <div id="nav-en-list" class="space-y-3"></div>
            <button id="add-nav-en" class="mt-4 bg-[#003865] text-white px-4 py-2 rounded text-sm">Add Nav Item</button>
          </div>
        </section>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <section class="bg-white rounded-lg p-6 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-[#003865]">中文融资栏目</h2>
            <button data-toggle-target="panel-finance-zh" class="text-sm border border-gray-300 px-3 py-1 rounded">收起</button>
          </div>
          <div id="panel-finance-zh">
            <div id="finance-zh-list" class="space-y-3"></div>
            <button id="add-finance-zh" class="mt-4 bg-[#003865] text-white px-4 py-2 rounded text-sm">新增融资条目</button>
          </div>
        </section>

        <section class="bg-white rounded-lg p-6 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-[#003865]">英文融资栏目</h2>
            <button data-toggle-target="panel-finance-en" class="text-sm border border-gray-300 px-3 py-1 rounded">收起</button>
          </div>
          <div id="panel-finance-en">
            <div id="finance-en-list" class="space-y-3"></div>
            <button id="add-finance-en" class="mt-4 bg-[#003865] text-white px-4 py-2 rounded text-sm">Add Finance Item</button>
          </div>
        </section>
      </div>

      <div class="bg-white rounded-lg p-6 shadow-sm flex flex-wrap gap-3">
        <button id="save-all" class="bg-[#E63E00] text-white px-5 py-2 rounded font-semibold">保存全部</button>
        <button id="reset-all" class="border border-gray-300 px-5 py-2 rounded">恢复默认</button>
        <p id="save-status" class="text-sm text-gray-500 self-center"></p>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ bootstrap }}>
  const K = {
    navZh: "lq_nav_zh",
    navEn: "lq_nav_en",
    financeZh: "lq_finance_zh",
    financeEn: "lq_finance_en",
  };

  const clone = (v) => JSON.parse(JSON.stringify(v));
  const load = (key, fallback) => {
    try {
      const text = localStorage.getItem(key);
      if (!text) return clone(fallback);
      const parsed = JSON.parse(text);
      return Array.isArray(parsed) ? parsed : clone(fallback);
    } catch {
      return clone(fallback);
    }
  };

  const state = {
    navZh: load(K.navZh, bootstrap.navZh),
    navEn: load(K.navEn, bootstrap.navEn),
    financeZh: load(K.financeZh, bootstrap.financeZh),
    financeEn: load(K.financeEn, bootstrap.financeEn),
  };

  const status = document.getElementById("save-status");
  const panelStateKey = "lq_admin_lite_panels";
  const panelState = (() => {
    try {
      const text = localStorage.getItem(panelStateKey);
      if (!text) return {};
      const parsed = JSON.parse(text);
      return parsed && typeof parsed === "object" ? parsed : {};
    } catch {
      return {};
    }
  })();
  const touch = (text) => {
    if (status) status.textContent = text;
  };

  const updateToggleLabel = (btn, expanded) => {
    btn.textContent = expanded ? "收起" : "展开";
  };

  const initPanelToggles = () => {
    document.querySelectorAll("button[data-toggle-target]").forEach((btn) => {
      const targetId = btn.dataset.toggleTarget;
      if (!targetId) return;
      const panel = document.getElementById(targetId);
      if (!panel) return;
      const expanded = panelState[targetId] !== false;
      panel.classList.toggle("hidden", !expanded);
      updateToggleLabel(btn, expanded);
      btn.onclick = () => {
        const nextExpanded = panel.classList.contains("hidden");
        panel.classList.toggle("hidden", !nextExpanded);
        panelState[targetId] = nextExpanded;
        localStorage.setItem(panelStateKey, JSON.stringify(panelState));
        updateToggleLabel(btn, nextExpanded);
      };
    });
  };

  const itemField = (value) => (value ?? "").toString().replaceAll('"', "&quot;");

  const renderNav = (id, list, lang) => {
    const root = document.getElementById(id);
    if (!root) return;
    root.innerHTML = list
      .map(
        (item, idx) => `
          <div class="grid grid-cols-12 gap-2 items-center">
            <input data-k="label" data-i="${idx}" class="col-span-5 border rounded px-2 py-1 text-sm" value="${itemField(item.label)}" placeholder="${lang === "zh" ? "名称" : "Label"}" />
            <input data-k="href" data-i="${idx}" class="col-span-5 border rounded px-2 py-1 text-sm" value="${itemField(item.href)}" placeholder="/zh/..." />
            <button data-del="${idx}" class="col-span-2 border border-red-300 text-red-600 rounded px-2 py-1 text-sm">删</button>
          </div>
        `,
      )
      .join("");
  };

  const renderFinance = (id, list, lang) => {
    const root = document.getElementById(id);
    if (!root) return;
    root.innerHTML = list
      .map(
        (item, idx) => `
          <div class="space-y-2 border rounded p-3">
            <div class="grid grid-cols-12 gap-2 items-center">
              <input data-k="title" data-i="${idx}" class="col-span-5 border rounded px-2 py-1 text-sm" value="${itemField(item.title)}" placeholder="${lang === "zh" ? "标题" : "Title"}" />
              <input data-k="order" data-i="${idx}" class="col-span-2 border rounded px-2 py-1 text-sm" value="${itemField(item.order)}" placeholder="排序" />
              <label class="col-span-3 text-sm"><input data-k="published" data-i="${idx}" type="checkbox" ${item.published === false ? "" : "checked"} /> 发布</label>
              <button data-del="${idx}" class="col-span-2 border border-red-300 text-red-600 rounded px-2 py-1 text-sm">删</button>
            </div>
            <textarea data-k="summary" data-i="${idx}" class="w-full border rounded px-2 py-1 text-sm" rows="2" placeholder="${lang === "zh" ? "简介" : "Summary"}">${itemField(item.summary)}</textarea>
          </div>
        `,
      )
      .join("");
  };

  const syncNav = (rootId, target) => {
    const root = document.getElementById(rootId);
    if (!root) return;
    root.querySelectorAll("input[data-i]").forEach((el) => {
      const i = Number(el.dataset.i);
      const k = el.dataset.k;
      if (!target[i] || !k) return;
      target[i][k] = el.value.trim();
    });
    root.querySelectorAll("button[data-del]").forEach((btn) => {
      btn.onclick = () => {
        const i = Number(btn.dataset.del);
        target.splice(i, 1);
        repaint();
      };
    });
  };

  const syncFinance = (rootId, target) => {
    const root = document.getElementById(rootId);
    if (!root) return;
    root.querySelectorAll("input[data-i],textarea[data-i]").forEach((el) => {
      const i = Number(el.dataset.i);
      const k = el.dataset.k;
      if (!target[i] || !k) return;
      if (k === "published") target[i][k] = el.checked;
      else if (k === "order") target[i][k] = Number(el.value || 0);
      else target[i][k] = el.value.trim();
    });
    root.querySelectorAll("button[data-del]").forEach((btn) => {
      btn.onclick = () => {
        const i = Number(btn.dataset.del);
        target.splice(i, 1);
        repaint();
      };
    });
  };

  const repaint = () => {
    renderNav("nav-zh-list", state.navZh, "zh");
    renderNav("nav-en-list", state.navEn, "en");
    renderFinance("finance-zh-list", state.financeZh, "zh");
    renderFinance("finance-en-list", state.financeEn, "en");

    syncNav("nav-zh-list", state.navZh);
    syncNav("nav-en-list", state.navEn);
    syncFinance("finance-zh-list", state.financeZh);
    syncFinance("finance-en-list", state.financeEn);
  };

  document.getElementById("add-nav-zh")?.addEventListener("click", () => {
    state.navZh.push({ label: "新导航", href: "/zh/" });
    repaint();
  });
  document.getElementById("add-nav-en")?.addEventListener("click", () => {
    state.navEn.push({ label: "New Nav", href: "/en/" });
    repaint();
  });

  document.getElementById("add-finance-zh")?.addEventListener("click", () => {
    state.financeZh.push({ id: `finance-zh-${Date.now()}`, title: "新融资条目", summary: "", order: state.financeZh.length + 1, published: true });
    repaint();
  });
  document.getElementById("add-finance-en")?.addEventListener("click", () => {
    state.financeEn.push({ id: `finance-en-${Date.now()}`, title: "New Finance Item", summary: "", order: state.financeEn.length + 1, published: true });
    repaint();
  });

  document.getElementById("save-all")?.addEventListener("click", () => {
    try {
      localStorage.setItem(K.navZh, JSON.stringify(state.navZh));
      localStorage.setItem(K.navEn, JSON.stringify(state.navEn));
      localStorage.setItem(K.financeZh, JSON.stringify(state.financeZh));
      localStorage.setItem(K.financeEn, JSON.stringify(state.financeEn));
      touch(`已保存 ${new Date().toLocaleString()}`);
    } catch {
      touch("保存失败，请检查浏览器权限");
    }
  });

  document.getElementById("reset-all")?.addEventListener("click", () => {
    localStorage.removeItem(K.navZh);
    localStorage.removeItem(K.navEn);
    localStorage.removeItem(K.financeZh);
    localStorage.removeItem(K.financeEn);
    state.navZh = clone(bootstrap.navZh);
    state.navEn = clone(bootstrap.navEn);
    state.financeZh = clone(bootstrap.financeZh);
    state.financeEn = clone(bootstrap.financeEn);
    repaint();
    touch("已恢复默认配置");
  });

  repaint();
  initPanelToggles();
</script>

