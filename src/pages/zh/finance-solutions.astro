---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import { siteConfig } from "../../config/site";
import { financeSolutionsZh } from "../../data/finance.zh";

const items = financeSolutionsZh
  .filter((item) => item.published)
  .sort((a, b) => a.order - b.order);
---

<Layout title="融资解决方案 | Lasting Qual" lang="zh-CN">
  <Header />

  <main>
    <div class="bg-[#003865] py-16">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-4xl font-extrabold text-white">融资解决方案</h1>
        <p class="mt-4 text-xl text-gray-300">聚焦油气工程装备与项目周期的资金解决方案</p>
      </div>
    </div>

    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="finance-list-zh" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {items.map((item) => (
            <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
              <h2 class="text-xl font-bold text-[#003865] mb-3">{item.title}</h2>
              <p class="text-gray-600 text-sm leading-relaxed">{item.summary}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <footer class="bg-[#002845] text-white py-8 border-t border-gray-700">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm">
        <p>&copy; {siteConfig.copyrightYear} {siteConfig.companyName} All rights reserved.</p>
      </div>
    </footer>
  </main>
</Layout>

<script define:vars={{ defaultItems: financeSolutionsZh }}>
  const key = "lq_finance_zh";
  const root = document.getElementById("finance-list-zh");

  const render = (list) => {
    if (!root) return;
    root.innerHTML = list
      .filter((item) => item && item.published !== false)
      .sort((a, b) => Number(a.order || 0) - Number(b.order || 0))
      .map(
        (item) => `
          <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
            <h2 class="text-xl font-bold text-[#003865] mb-3">${item.title || "未命名"}</h2>
            <p class="text-gray-600 text-sm leading-relaxed">${item.summary || ""}</p>
          </article>
        `,
      )
      .join("");
  };

  try {
    const text = localStorage.getItem(key);
    if (text) {
      const localItems = JSON.parse(text);
      if (Array.isArray(localItems)) {
        render(localItems);
      }
    } else {
      render(defaultItems);
    }
  } catch {
    render(defaultItems);
  }
</script>
