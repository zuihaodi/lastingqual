---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import UnifiedSimplePage from "../../components/UnifiedSimplePage.astro";
import { siteConfig } from "../../config/site";
import { loadCardsByLangPage, loadSimplePageByLang } from "../../lib/content-loader";

const cfg = loadSimplePageByLang("solutions", "zh");
const cards = loadCardsByLangPage("zh", "solutions").filter((c) => c.title && c.summary);
---

<Layout title={`${cfg?.heroTitle || "Support System"} | Lasting Qual`} lang="zh-CN">
  <Header />
  <UnifiedSimplePage cfg={cfg} cards={cards} lang="zh" />
  <footer class="bg-[#002845] text-white py-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      <p>&copy; {siteConfig.copyrightYear} {siteConfig.companyName} All rights reserved.</p>
    </div>
  </footer>
</Layout>
