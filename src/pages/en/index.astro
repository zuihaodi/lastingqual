---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/HeaderEN.astro";
import { siteConfig } from "../../config/site";
import { loadCardsByLangPage, loadHomeByLang, loadProductsByLang } from "../../lib/content-loader";
import type { CmsCardItem, CmsHomeConfig, CmsProductItem } from "../../types/content";

const fallbackHome: CmsHomeConfig = {
  hero: {
    titleLine1: "Challenging Deep Earth",
    titleLine2: "Setting New Asian Records",
    subtitle:
      "Mastering 12,000m ultra-deep drilling technology. Holder of the 9,396m Asian depth record.\nLasting Qual - Your most trusted energy partner.",
    buttonPrimaryText: "Our Business",
    buttonPrimaryHref: "/en/products",
    buttonSecondaryText: "Contact Us",
    buttonSecondaryHref: "/en/contact",
    bgImage: "/images/hero-bg.jpg",
  },
  metrics: [
    { value: "2002", unit: "", desc: "Established Since" },
    { value: "9,396", unit: "m", desc: "Asian Drilling Record" },
    { value: "CNPC", unit: "", desc: "Tier-1 Supplier" },
    { value: "ISO", unit: "", desc: "Certified Quality" },
  ],
  businessSection: {
    show: true,
    title: "Core Business Areas",
    desc: "A multinational enterprise integrating R&D, manufacturing, rental, trading, and services.",
  },
  cta: {
    title: "Industry-Leading Supply Chain",
    desc: "From the Tarim Desert to Mexican oilfields, we provide precise customized services.",
    buttonText: "Get a Quote",
    buttonHref: "/en/contact",
  },
};

const homeConfig = loadHomeByLang("en") || fallbackHome;
const metrics = homeConfig.metrics?.length ? homeConfig.metrics : fallbackHome.metrics;

const productFallback: CmsProductItem[] = [
  { category: "Rental Service", title: "High-end Rig Rental", summary: "High-end rig leasing for ultra-deep drilling scenarios.", cover: "/images/card1.jpg", ctaHref: "/en/contact", order: 1, published: true },
  { category: "Sales Business", title: "Oilfield Special Chassis", summary: "8x6 fracturing chassis and specialized field chassis solutions.", cover: "/images/card2.jpg", ctaHref: "/en/contact", order: 2, published: true },
  { category: "Tech Service", title: "Power Packaging Services", summary: "One-stop power solutions for drilling rigs.", cover: "/images/card3.jpg", ctaHref: "/en/contact", order: 3, published: true },
];

const cmsProducts = loadProductsByLang("en").filter((p) => p.title && p.summary && p.cover);
const cardsEnabled = homeConfig.cardsSection?.show !== false;
const cards = cardsEnabled ? loadCardsByLangPage("en", "home").filter((c) => c.title && c.summary) : [];
const bottomListEnabled = homeConfig.bottomListSection?.show !== false;
const bottomList = homeConfig.bottomListSection?.bottomList || homeConfig.bottomList || [];
const topProducts = (
  cards.length
    ? cards.map((c: CmsCardItem) => ({
        title: c.title || "",
        summary: c.summary || "",
        cover: c.image || "/images/card1.jpg",
        ctaText: c.ctaText || "Read More",
        ctaHref: c.ctaHref || "/en/contact",
      }))
    : cmsProducts.length
      ? cmsProducts.map((p) => ({
          ...p,
          ctaText: "Read More",
        }))
      : productFallback
);
---

<Layout title="Lasting Qual - Integrated Energy Equipment Provider" lang="en">
  <Header />

  <main>
    <section class="relative h-[700px] flex items-center bg-slate-900">
      <div class="absolute inset-0 overflow-hidden">
        <img src={homeConfig.hero.bgImage} alt="Drilling Site" class="w-full h-full object-cover opacity-50" />
      </div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-white mt-10">
        <h1 class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
          {homeConfig.hero.titleLine1}<br />
          <span class="text-[#E63E00]">{homeConfig.hero.titleLine2}</span>
        </h1>
        <p class="text-xl md:text-2xl mb-10 max-w-2xl text-gray-200 font-light whitespace-pre-line">{homeConfig.hero.subtitle}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={homeConfig.hero.buttonPrimaryHref} class="bg-[#E63E00] text-white px-8 py-4 rounded font-bold text-center hover:bg-orange-700 transition uppercase tracking-wider no-underline">{homeConfig.hero.buttonPrimaryText}</a>
          <a href={homeConfig.hero.buttonSecondaryHref} class="bg-transparent border-2 border-white text-white px-8 py-4 rounded font-bold text-center hover:bg-white hover:text-[#003865] transition uppercase tracking-wider no-underline">{homeConfig.hero.buttonSecondaryText}</a>
        </div>
      </div>
    </section>

    <section class="bg-[#003865] py-10 border-b-4 border-[#E63E00]">
      <div class="max-w-7xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center text-white">
        {metrics.map((metric) => (
          <div>
            <div class="text-4xl font-bold mb-1">{metric.value}{metric.unit && <span class="text-xl font-normal">{metric.unit}</span>}</div>
            <div class="text-gray-300 text-sm">{metric.desc}</div>
          </div>
        ))}
      </div>
    </section>

    {homeConfig.businessSection?.show === true && cardsEnabled && (
      <section class="py-24 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16">
            <h2 class="text-4xl font-extrabold text-[#003865] mb-4">{homeConfig.businessSection?.title || "Core Business Areas"}</h2>
            <div class="w-20 h-1 bg-[#E63E00] mx-auto"></div>
            <p class="mt-4 text-gray-600 max-w-2xl mx-auto">{homeConfig.businessSection?.desc || ""}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            {topProducts.map((item) => (
              <div class="group bg-white shadow-xl rounded overflow-hidden hover:-translate-y-2 transition duration-300">
                <div class="h-56 overflow-hidden">
                  <img src={item.cover || "/images/card1.jpg"} alt={item.title || "Product"} class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                </div>
                <div class="p-8">
                  <h3 class="text-2xl font-bold mb-3 text-[#003865]">{item.title}</h3>
                  <p class="text-gray-600 mb-6 leading-relaxed">{item.summary}</p>
                  <a href={item.ctaHref || "/en/contact"} class="text-[#E63E00] font-bold uppercase tracking-wide hover:underline">{item.ctaText || "Read More"} &rarr;</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {bottomListEnabled && bottomList.length > 0 && (
      <section class="py-16 bg-gray-50">
        <div class="max-w-5xl mx-auto px-4">
          <h2 class="text-3xl font-extrabold text-[#003865] mb-8 text-center">Bottom List Section</h2>
          <div class="bg-white border border-gray-200 rounded divide-y divide-gray-200">
            {bottomList.map((item) => (
              <div class="p-6">
                <h3 class="text-xl font-bold text-[#003865] mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.summary}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="bg-[#003865] py-12">
      <div class="max-w-5xl mx-auto px-4 text-center">
        <h2 class="text-2xl font-bold text-white mb-4">{homeConfig.cta.title}</h2>
        <p class="text-gray-300 mb-8">{homeConfig.cta.desc}</p>
        <a href={homeConfig.cta.buttonHref} class="bg-white text-[#003865] px-8 py-3 rounded font-bold hover:bg-gray-100 transition no-underline">{homeConfig.cta.buttonText}</a>
      </div>
    </section>

    <footer class="bg-[#002845] text-white py-12 border-t-4 border-[#E63E00]">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-400">
        <p class="mb-2">&copy; {siteConfig.copyrightYear} {siteConfig.companyName} All rights reserved.</p>
        <p>Committed to promoting technological progress and efficiency in the energy industry.</p>
      </div>
    </footer>
  </main>
</Layout>

