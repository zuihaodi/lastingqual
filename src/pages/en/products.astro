---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/HeaderEN.astro";
import UnifiedSimplePage from "../../components/UnifiedSimplePage.astro";
import { siteConfig } from "../../config/site";
import { loadCardsByLangPage, loadProductsByLang, loadSimplePageByLang } from "../../lib/content-loader";

const cfg = loadSimplePageByLang("products", "en");
const cards = loadCardsByLangPage("en", "products").filter((c) => c.title && c.summary);
const legacyCards = loadProductsByLang("en")
  .filter((p) => p.title && p.summary)
  .map((p) => ({ title: p.title, summary: p.summary, image: p.cover, ctaText: "Read More", ctaHref: p.ctaHref || "/en/contact", order: p.order, published: p.published }));
const mergedCards = cards.length > 0 ? cards : legacyCards;
---

<Layout title={`${cfg?.heroTitle || "Products"} | Lasting Qual`} lang="en">
  <Header />
  <UnifiedSimplePage cfg={cfg} cards={mergedCards} lang="en" />
  <footer class="bg-[#002845] text-white py-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      <p>&copy; {siteConfig.copyrightYear} {siteConfig.companyName} All rights reserved.</p>
    </div>
  </footer>
</Layout>
